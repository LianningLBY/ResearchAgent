# ============================================================
# 研智 (YanZhi) 环境变量配置模板
# 使用方法：复制本文件为 .env，填入真实值后保存
#   cp .env.example .env
# ============================================================


# ------------------------------------------------------------
# LLM API 密钥（至少配置一个）
# ------------------------------------------------------------

# Google Gemini（推荐，免费额度较大）
# 获取地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# OpenAI
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Anthropic Claude
# 获取地址：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Perplexity（用于论文自动添加参考文献，可选）
# 获取地址：https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=""

# Semantic Scholar（用于文献查新，免费但有速率限制；不填也可使用）
# 获取地址：https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=""


# ------------------------------------------------------------
# 云数据库配置（可选，用于跨设备持久化存储对话记录和项目数据）
# 不配置则使用本地文件存储（projects/ 目录）
# ------------------------------------------------------------

# --- 方案：Supabase（推荐）---
# 注册地址：https://supabase.com（免费，500MB 存储）
# 步骤：
#   1. 注册并创建一个新项目
#   2. 进入 Project Settings → API
#   3. 复制 Project URL 和 anon public key
SUPABASE_URL=""
SUPABASE_KEY=""

# 建表 SQL（在 Supabase SQL Editor 中执行）：
#
#   -- 项目表
#   CREATE TABLE projects (
#     id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#     name TEXT UNIQUE NOT NULL,
#     created_at TIMESTAMPTZ DEFAULT now()
#   );
#
#   -- 文件内容表（存储 idea.md / methods.md 等）
#   CREATE TABLE project_files (
#     id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#     project_id UUID REFERENCES projects(id) ON DELETE CASCADE,
#     file_type TEXT NOT NULL,   -- 'idea' | 'methods' | 'literature' | 'description' | 'results'
#     content TEXT,
#     updated_at TIMESTAMPTZ DEFAULT now(),
#     UNIQUE(project_id, file_type)
#   );
#
#   -- 对话记录表
#   CREATE TABLE chat_history (
#     id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#     project_id UUID REFERENCES projects(id) ON DELETE CASCADE,
#     page_key TEXT NOT NULL,    -- 'idea' | 'methods' | 'direction'
#     messages JSONB DEFAULT '[]',
#     updated_at TIMESTAMPTZ DEFAULT now(),
#     UNIQUE(project_id, page_key)
#   );


# --- 备选方案：Firebase Firestore ---
# 注册地址：https://console.firebase.google.com（免费，1GB 存储）
# 步骤：
#   1. 创建项目 → 启用 Firestore → 生成服务账号密钥 JSON
#   2. 将 JSON 文件路径填入下方
# FIREBASE_CREDENTIALS_PATH="/path/to/serviceAccountKey.json"
# FIREBASE_PROJECT_ID=""


# --- 备选方案：MongoDB Atlas ---
# 注册地址：https://www.mongodb.com/cloud/atlas（免费，512MB）
# MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/yanzhi"
